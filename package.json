{
  "name": "@univer-community/sheets-csv-import-export",
  "version": "0.22.0",
  "description": "A plugin for importing and exporting CSV files in Univer Sheets.",
  "keywords": [
    "export",
    "import",
    "univer"
  ],
  "homepage": "https://github.com/univer-community",
  "license": "MIT",
  "author": "白熱 <sonne@asaki.me>",
  "repository": {
    "type": "git",
    "url": "https://github.com/univer-community/sheets-csv-import-export.git"
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "main": "./src/index.ts",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./facade": "./src/facade/index.ts"
  },
  "publishConfig": {
    "main": "./lib/es/index.js",
    "module": "./lib/es/index.js",
    "exports": {
      ".": {
        "import": "./lib/es/index.js",
        "require": "./lib/cjs/index.js",
        "types": "./lib/types/index.d.ts"
      },
      "./*": {
        "import": "./lib/es/*",
        "require": "./lib/cjs/*",
        "types": "./lib/types/index.d.ts"
      },
      "./facade": {
        "import": "./lib/es/facade.js",
        "require": "./lib/cjs/facade.js",
        "types": "./lib/types/facade/index.d.ts"
      },
      "./lib/facade": {
        "import": "./lib/es/facade.js",
        "require": "./lib/cjs/facade.js",
        "types": "./lib/types/facade/index.d.ts"
      },
      "./lib/*": "./lib/*"
    },
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "build": "pnpm run build:bundle && pnpm run build:types",
    "build:bundle": "node ./scripts/build.mjs build --cleanup",
    "build:demo": "vite build --config vite.demo.config.ts",
    "build:types": "tsc -p tsconfig.node.json",
    "coverage": "vitest run --coverage",
    "dev": "vite --config vite.demo.config.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@univerjs/core": "^0.23.0",
    "@univerjs/sheets": "^0.23.0",
    "@univerjs/sheets-ui": "^0.23.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@univerjs/design": "^0.23.0",
    "@univerjs/docs": "^0.23.0",
    "@univerjs/docs-ui": "^0.23.0",
    "@univerjs/engine-formula": "^0.23.0",
    "@univerjs/engine-render": "^0.23.0",
    "@univerjs/sheets-formula": "^0.23.0",
    "@univerjs/sheets-formula-ui": "^0.23.0",
    "@univerjs/sheets-numfmt": "^0.23.0",
    "@univerjs/sheets-numfmt-ui": "^0.23.0",
    "@univerjs/ui": "^0.23.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint:fix && pnpm fmt"
  },
  "packageManager": "pnpm@11.1.3"
}
